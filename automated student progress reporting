import pandas as pd
import numpy as np
import os

# PROJECT 1: STUDENT DATA 
print("RUNNING STUDENT NOTIFICATION SYSTEM")

file_name = 'student_data.csv'

if os.path.exists(file_name):
    # Load your existing data
    df = pd.read_csv(file_name)
    print(f"Success: {file_name} loaded.")

    # Creating a 'Status' column based on your criteria
    # If a grade is below 60, it flags them automatically
    if 'Grade' in df.columns:
        df['Status'] = np.where(df['Grade'] < 60, "NEEDS SUPPORT", "ON TRACK")
        
        print("\n GENERATED REPORT ")
        print(df.head(10))

        total_support = (df['Status'] == "NEEDS SUPPORT").sum()
        print(f"Audit Complete: {total_support} students flagged for support.")

        df.to_csv('student_report.csv', index=False)
        print("\nReport saved as: student_report.csv")
    else:
        print("Note: Could not find a 'Grade' column in your file.")
        print(f"I found these columns instead: {df.columns.tolist()}")

else:
    print(f"Error: The file '{file_name}' was not found in this folder.")
