import pandas as pd
import numpy as np
import os

# Configuration
file_name = 'student_data.csv'
passing_mark = 60

print("--- STARTING STUDENT DATA AUDIT ---")

if os.path.exists(file_name):
    # Load the clean file - now it works perfectly with Name and Grade
    df = pd.read_csv(file_name)
    
    # Simple, powerful logic
    df['Status'] = np.where(df['Grade'] < passing_mark, "NEEDS SUPPORT", "ON TRACK")
    
    # Show Results in the console
    print("\nProcessed Student Report:")
    print(df[['Name', 'Grade', 'Status']].to_string(index=False))
    
    # Save the professional result for your records
    df.to_csv('student_audit_report.csv', index=False)
    print(f"\nSuccess: Audit complete. {len(df)} records processed.")
else:
    print(f"Error: File '{file_name}' not found. Please upload it to the Colab sidebar.")
